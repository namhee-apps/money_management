# Streamlit Cloud → Settings → Secrets 에 아래 내용을 붙여넣으세요
# (이 파일 자체는 GitHub에 올라가지만, 실제 값은 Streamlit Cloud Secrets에만 입력)
#
# ▼ 값이 한 번이라도 Secrets에 들어가면 컨테이너가 재시작되어도 유지됩니다.
#   앱 내 UI에서 저장한 값은 세션 동안만 유효하고 재시작 시 사라지므로,
#   "연동한 정보가 자꾸 사라진다"는 현상이 나타나면 여기에 값을 넣어주세요.

# ─────────────────────────────────────────────────────────────
# 로그인 (아이디 + 비밀번호, 30일 쿠키 유지)
# ─────────────────────────────────────────────────────────────
# 절대 직접 입력하지 말고, 아래 스크립트를 실행해서 생성된 블록을 그대로 붙여넣으세요.
# (비밀번호는 bcrypt로 해시되어 평문 노출 없음)
#
#   .venv/bin/python set_auth.py
#
# 실행하면 AUTH_USERNAME / AUTH_NAME / AUTH_PASSWORD_HASH / AUTH_COOKIE_KEY 네 값이 출력됩니다.
AUTH_USERNAME = ""
AUTH_NAME = ""
AUTH_PASSWORD_HASH = ""
AUTH_COOKIE_KEY = ""
# (선택) 로그인 유지 기간 — 기본 30일
# AUTH_COOKIE_EXPIRY_DAYS = "30"

ANTHROPIC_API_KEY = "sk-ant-..."
TELEGRAM_BOT_TOKEN = "7123456789:AAF..."
TELEGRAM_CHAT_ID = "1234567890"
NOTIFICATION_TIME = "08:20, 12:20, 21:00"
DAILY_REPORT_TIME = "19:00"
GOOGLE_SHEETS_ID = ""

# ─────────────────────────────────────────────────────────────
# Google Sheets OAuth refresh token (Cloud/모바일용)
# ─────────────────────────────────────────────────────────────
# 설정 방법:
#   1) Mac에서 앱을 한 번 실행하고 Google 계정으로 로그인 → `google_token.json` 생성됨
#   2) `google_token.json` 파일 내용 전체를 아래에 한 줄 JSON 문자열로 붙여넣기
#      (개행 제거, 따옴표는 이스케이프 처리)
#   3) 이 토큰 하나로 웹·모바일 어디서 열어도 같은 시트에 연결됩니다.
#
# 예시:
# GOOGLE_OAUTH_TOKEN = '{"refresh_token": "1//0g...", "client_id": "...apps.googleusercontent.com", "client_secret": "GOCSPX-...", "token_uri": "https://oauth2.googleapis.com/token", "scopes": ["https://www.googleapis.com/auth/spreadsheets", "https://www.googleapis.com/auth/drive"]}'
GOOGLE_OAUTH_TOKEN = ""

# 서비스 계정 방식을 쓸 경우 (GOOGLE_OAUTH_TOKEN 대신)
GOOGLE_CREDENTIALS_JSON = ""
